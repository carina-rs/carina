arguments {
  region: String {
    description = 'AWS region'
  }
}

attributes {
  bucket_id: awscc.s3.Bucket = logs_bucket.id
  queue_url: awscc.sqs.Queue = event_queue.id
}

let logs_bucket = awscc.s3.Bucket {
  bucket_name = 'app-logs'
}

let event_queue = awscc.sqs.Queue {
  queue_name = 'events'
}
