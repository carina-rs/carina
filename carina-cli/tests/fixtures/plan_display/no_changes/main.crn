# No changes - state matches desired

provider awscc {
  region = awscc.Region.ap_northeast_1
}

let vpc = awscc.ec2.vpc {
  cidr_block           = '10.0.0.0/16'
  enable_dns_support   = true
  enable_dns_hostnames = true

  tags = {
    Name = 'test-vpc'
  }
}

awscc.ec2.subnet {
  vpc_id     = vpc.vpc_id
  cidr_block = '10.0.1.0/24'

  tags = {
    Name = 'test-subnet'
  }
}
