# Test upstream_state: reference another project's state

provider awscc {
  region = awscc.Region.ap_northeast_1
}

upstream_state "network" {
  source = "./network"
}

awscc.ec2.security_group {
  group_description = 'Web security group'
  vpc_id            = network.vpc.vpc_id

  tags = {
    Name = 'web-sg'
  }
}
