provider awscc {
  region = awscc.Region.ap_northeast_1
}

fn tagged_vpc(cidr: string, env: string): awscc.ec2.vpc {
  awscc.ec2.vpc {
    cidr_block = cidr

    tags = {
      Name        = join("-", [env, "vpc"])
      Environment = env
    }
  }
}

let dev_vpc  = tagged_vpc("10.0.0.0/16", "dev")
let stg_vpc  = tagged_vpc("10.1.0.0/16", "stg")
