# EC2 Security Group - Basic test
#
# Tests: security group creation with vpc, description, tags

provider aws {
  region = aws.Region.ap_northeast_1
}

let vpc = aws.ec2.vpc {
  cidr_block = "10.0.0.0/16"

  tags = {
    Environment = "acceptance-test"
  }
}

let sg = aws.ec2.security_group {
  group_name  = "carina-acc-test-aws-sg-basic"
  description = "Acceptance test security group"
  vpc_id      = vpc.vpc_id

  tags = {
    Environment = "acceptance-test"
  }
}
