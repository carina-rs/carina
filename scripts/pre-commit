#!/bin/bash
# Pre-commit hook for Carina
# Install: ./scripts/setup-hooks.sh

set -e

echo "Running pre-commit checks..."

# Check formatting
echo "Checking formatting..."
cargo fmt --all -- --check
echo "Formatting OK"

# Run clippy
echo "Running clippy..."
cargo clippy --all-targets --all-features -- -D warnings
echo "Clippy OK"

echo ""
echo "All pre-commit checks passed!"
