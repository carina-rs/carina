// Carina DSL Grammar for Formatting
// Unlike the semantic parser, this grammar captures whitespace and comments

// Entry point - captures everything including trivia
file = { SOI ~ file_content* ~ EOI }
file_content = _{ trivia | statement }

// Trivia: whitespace and comments that we want to preserve.
//
// The main parser accepts `//` and `#` line comments plus `/* ... */`
// block comments (see `carina.pest`'s `line_comment` / `block_comment`).
// The formatter has to accept the same three forms or it can't parse
// real source — for example the `identity-center/` fixture uses `//`
// comments inside attribute blocks.
trivia = { ws | comment | newline }
ws = @{ (" " | "\t")+ }
newline = @{ NEWLINE }
comment = _{ line_comment | block_comment }
line_comment = @{ ("//" | "#") ~ (!NEWLINE ~ ANY)* }
block_comment = @{ "/*" ~ (!"*/" ~ ANY)* ~ "*/" }

statement = { backend_block | provider_block | arguments_block | attributes_block | exports_block | import_state_block | removed_block | moved_block | require_statement | if_expr | for_expr | fn_def | let_binding | module_call | anonymous_resource }

// Require statement: require <validate_expr>, "error message"
require_statement = {
    kw_require ~ trivia+ ~ validate_expr ~ trivia* ~ comma ~ trivia* ~ string
}

// Backend block: backend s3 { ... }
backend_block = {
    kw_backend ~ trivia+ ~ identifier ~ trivia* ~ open_brace ~ block_content* ~ close_brace
}

// Anonymous resource: aws.s3_bucket { ... }
anonymous_resource = {
    namespaced_id ~ trivia* ~ open_brace ~ block_content* ~ close_brace
}

// Module call: module_name { key = value, ... }
module_call = {
    identifier ~ trivia* ~ open_brace ~ block_content* ~ close_brace
}

// Provider block: provider aws { ... }
provider_block = {
    kw_provider ~ trivia+ ~ identifier ~ trivia* ~ open_brace ~ block_content* ~ close_brace
}

// Arguments block: arguments { name: type, name: type = default }
arguments_block = {
    kw_arguments ~ trivia* ~ open_brace ~ arguments_block_content* ~ close_brace
}

arguments_block_content = _{ trivia | arguments_param }

// Arguments parameter: name: type or name: type = default, or block form
arguments_param = {
    identifier ~ trivia* ~ colon ~ trivia* ~ type_expr ~ trivia* ~ arguments_param_block
  | identifier ~ trivia* ~ colon ~ trivia* ~ type_expr ~ (trivia* ~ equals ~ trivia* ~ expression)?
}

arguments_param_block = {
    open_brace ~ arguments_param_block_content* ~ close_brace
}

arguments_param_block_content = _{ trivia | arguments_param_attr }

arguments_param_attr = {
    kw_description ~ trivia* ~ equals ~ trivia* ~ string
  | kw_default ~ trivia* ~ equals ~ trivia* ~ expression
  | kw_validation ~ trivia* ~ open_brace ~ validation_block_content* ~ close_brace
}

validation_block_content = _{ trivia | validation_block_attr }

validation_block_attr = {
    kw_condition ~ trivia* ~ equals ~ trivia* ~ validate_expr
  | kw_error_message ~ trivia* ~ equals ~ trivia* ~ string
}

kw_description = { "description" }
kw_default = { "default" }
kw_validation = { "validation" }
kw_condition = { "condition" }
kw_error_message = { "error_message" }

// Validate expression for formatter (preserves tokens)
validate_expr = { validate_or_expr }
validate_or_expr = { validate_and_expr ~ (trivia* ~ op_or ~ trivia* ~ validate_and_expr)* }
validate_and_expr = { validate_not_expr ~ (trivia* ~ op_and ~ trivia* ~ validate_not_expr)* }
validate_not_expr = { op_not ~ trivia* ~ validate_not_expr | validate_comparison }
validate_comparison = { validate_primary ~ (trivia* ~ compare_op ~ trivia* ~ validate_primary)? }
compare_op = { ">=" | "<=" | "!=" | "==" | ">" | "<" }
op_and = { "&&" }
op_or = { "||" }
op_not = { "!" }
validate_primary = {
    validate_function_call
  | null_literal
  | boolean
  | float
  | number
  | string
  | variable_ref
  | open_paren ~ trivia* ~ validate_expr ~ trivia* ~ close_paren
}
null_literal = { "null" ~ !(ASCII_ALPHANUMERIC | "_") }
validate_function_call = { identifier ~ open_paren ~ (trivia* ~ validate_expr ~ (trivia* ~ comma ~ trivia* ~ validate_expr)*)? ~ trivia* ~ close_paren }

// Attributes block: attributes { name: type = value }
attributes_block = {
    kw_attributes ~ trivia* ~ open_brace ~ attributes_block_content* ~ close_brace
}

attributes_block_content = _{ trivia | attributes_param }

// Attributes parameter: name: type = value, or name = value (type optional)
attributes_param = {
    identifier ~ trivia* ~ colon ~ trivia* ~ type_expr ~ trivia* ~ equals ~ trivia* ~ expression
  | identifier ~ trivia* ~ equals ~ trivia* ~ expression
}

// Exports block: exports { name: type = value }
exports_block = {
    kw_exports ~ trivia* ~ open_brace ~ exports_block_content* ~ close_brace
}

exports_block_content = _{ trivia | exports_param }

// Exports parameter: name: type = value, or name = value (type optional)
exports_param = {
    identifier ~ trivia* ~ colon ~ trivia* ~ type_expr ~ trivia* ~ equals ~ trivia* ~ expression
  | identifier ~ trivia* ~ equals ~ trivia* ~ expression
}

// Type expression: string, bool, int, cidr, arn, etc., list(type), map(type), aws.resource (resource ref), struct { field: type, ... }
type_expr = {
    type_struct | type_ref | type_list | type_map | type_primitive
}

type_primitive = @{ identifier }

type_list = { kw_list ~ trivia* ~ open_paren ~ trivia* ~ type_expr ~ trivia* ~ close_paren }

type_map = { kw_map ~ trivia* ~ open_paren ~ trivia* ~ type_expr ~ trivia* ~ close_paren }

type_ref = { namespaced_id }

type_struct = { kw_struct ~ trivia* ~ open_brace ~ trivia* ~ struct_field_list? ~ trivia* ~ close_brace }

struct_field_list = { struct_field ~ (trivia* ~ comma ~ trivia* ~ struct_field)* ~ (trivia* ~ comma)? }

struct_field = { identifier ~ trivia* ~ colon ~ trivia* ~ type_expr }

// State manipulation blocks

// Resource address: provider.service.type "name"
resource_address = { namespaced_id ~ trivia* ~ string }

// Import state block: import { to = awscc.ec2.vpc "name", id = "vpc-xxx" }
import_state_block = {
    kw_import ~ trivia* ~ open_brace ~ import_state_content* ~ close_brace
}
import_state_content = _{ trivia | import_to_attr | import_id_attr }
import_to_attr = { kw_to ~ trivia* ~ equals ~ trivia* ~ resource_address }
import_id_attr = { kw_id ~ trivia* ~ equals ~ trivia* ~ string }

// Removed block: removed { from = awscc.ec2.vpc "name" }
removed_block = {
    kw_removed ~ trivia* ~ open_brace ~ removed_content* ~ close_brace
}
removed_content = _{ trivia | removed_from_attr }
removed_from_attr = { kw_from ~ trivia* ~ equals ~ trivia* ~ resource_address }

// Moved block: moved { from = awscc.ec2.vpc "old", to = awscc.ec2.vpc "new" }
moved_block = {
    kw_moved ~ trivia* ~ open_brace ~ moved_content* ~ close_brace
}
moved_content = _{ trivia | moved_from_attr | moved_to_attr }
moved_from_attr = { kw_from ~ trivia* ~ equals ~ trivia* ~ resource_address }
moved_to_attr = { kw_to ~ trivia* ~ equals ~ trivia* ~ resource_address }

// User-defined function: fn name(params) { body }
fn_def = {
    kw_fn ~ trivia+ ~ identifier ~ trivia* ~ open_paren ~ fn_params_content* ~ close_paren ~ (trivia* ~ colon ~ trivia* ~ type_expr)? ~ trivia* ~ open_brace ~ fn_body_content* ~ close_brace
}
fn_params_content = _{ trivia | comma | fn_param }
fn_param = { identifier ~ (trivia* ~ colon ~ trivia* ~ type_expr)? ~ (trivia* ~ equals ~ trivia* ~ expression)? }
fn_body_content = _{ trivia | fn_local_let | expression }
fn_local_let = { kw_let ~ trivia+ ~ identifier ~ trivia* ~ equals ~ trivia* ~ expression }

// Variable/resource definition: let name = value
// discard_pattern allows `let _ = expr` to suppress unused binding warnings
discard_pattern = @{ "_" }
let_binding = {
    kw_let ~ trivia+ ~ (discard_pattern | identifier) ~ trivia* ~ equals ~ trivia* ~ expression
}

// Block content: local let bindings, attributes, trivia, nested blocks, or nested elements
block_content = _{ trivia | local_binding | nested_block | attribute }

// Local let binding inside a block: let name = expression
local_binding = {
    kw_let ~ trivia+ ~ identifier ~ trivia* ~ equals ~ trivia* ~ expression
}

// Nested block: identifier { ... } (e.g., lifecycle { ... }, security_group_ingress { ... })
nested_block = {
    identifier ~ trivia* ~ open_brace ~ block_content* ~ close_brace
}

// Attribute: key = value (key can be identifier or quoted string)
attribute = { (identifier | string) ~ trivia* ~ equals ~ trivia* ~ expression }

identifier = @{ ASCII_ALPHA ~ (ASCII_ALPHANUMERIC | "_")* }

// Namespaced identifier: aws.s3_bucket, aws.Region.ap_northeast_1, Type.ipsec.1
namespaced_id = @{ identifier ~ ("." ~ (identifier | ASCII_DIGIT+))+ }

// Expression
expression = { pipe_expr }

// Pipe operator: value |> func |> func
pipe_expr = { compose_expr ~ (trivia* ~ pipe_op ~ trivia* ~ function_call)* }

// Compose operator: f >> g (function composition)
compose_expr = { primary ~ (trivia* ~ compose_op ~ trivia* ~ primary)* }

// Function call: func(args)
function_call = {
    identifier ~ open_paren ~ (trivia* ~ expression ~ (trivia* ~ comma ~ trivia* ~ expression)*)? ~ trivia* ~ close_paren
}

// Use expression: use { source = "path" } (used in let binding RHS)
// Mirrors carina.pest:14 upstream_state_expr shape.
use_expr = {
    kw_use ~ trivia* ~ open_brace ~ block_content* ~ close_brace
}

// Upstream state expression: upstream_state { source = '..' }
// Used as the RHS of a `let` binding — mirrors carina.pest:14.
upstream_state_expr = {
    kw_upstream_state ~ trivia* ~ open_brace ~ block_content* ~ close_brace
}

// Primary value
primary = {
    read_resource_expr
  | upstream_state_expr
  | resource_expr
  | use_expr
  | for_expr
  | if_expr
  | function_call
  | list
  | map
  | namespaced_id
  | boolean
  | float
  | number
  | string
  | variable_ref
  | open_paren ~ trivia* ~ expression ~ trivia* ~ close_paren
}

// List: [item1, item2, ...]
list = {
    open_bracket ~ trivia* ~ (expression ~ (trivia* ~ comma ~ trivia* ~ expression)*)? ~ trivia* ~ comma? ~ trivia* ~ close_bracket
}

// Map: { key = value, ... } (commas are optional)
map = {
    open_brace ~ map_content* ~ close_brace
}

map_content = _{ trivia | nested_block | map_entry }

// Map entry: key = value (with optional trailing comma, key can be identifier or quoted string)
map_entry = { (identifier | string) ~ trivia* ~ equals ~ trivia* ~ expression ~ trivia* ~ comma? }

// For expression: for var in iterable { body }
for_expr = {
    kw_for ~ trivia+ ~ for_binding ~ trivia+ ~ kw_in ~ trivia+ ~ for_iterable ~ trivia* ~ open_brace ~ for_body_content* ~ close_brace
}

// For binding: simple (x), indexed ((i, x)), or map (k, v)
for_binding = { for_indexed_binding | for_map_binding | for_simple_binding }
for_simple_binding = { discard_pattern | identifier }
for_indexed_binding = {
    open_paren ~ trivia* ~ (discard_pattern | identifier) ~ trivia* ~ comma ~ trivia* ~ (discard_pattern | identifier) ~ trivia* ~ close_paren
}
for_map_binding = {
    (discard_pattern | identifier) ~ trivia* ~ comma ~ trivia+ ~ (discard_pattern | identifier)
}

// For iterable: restricted to simple expressions
for_iterable = { function_call | list | variable_ref | open_paren ~ trivia* ~ expression ~ trivia* ~ close_paren }

// For body content
for_body_content = _{ trivia | for_local_binding | read_resource_expr | resource_expr | module_call }

// For local binding: let name = expression
for_local_binding = { kw_let ~ trivia+ ~ identifier ~ trivia* ~ equals ~ trivia* ~ expression }

// If expression: if condition { body } else { body }
if_expr = {
    kw_if ~ trivia+ ~ expression ~ trivia* ~ open_brace ~ if_body_content* ~ close_brace ~ (trivia* ~ else_clause)?
}
else_clause = { kw_else ~ trivia* ~ open_brace ~ if_body_content* ~ close_brace }

// If body content
if_body_content = _{ trivia | if_local_binding | read_resource_expr | resource_expr | module_call | expression }

// If local binding: let name = expression
if_local_binding = { kw_let ~ trivia+ ~ identifier ~ trivia* ~ equals ~ trivia* ~ expression }

// Resource expression: aws.s3_bucket { ... }
resource_expr = {
    namespaced_id ~ trivia* ~ open_brace ~ block_content* ~ close_brace
}

// Read resource expression: read aws.s3_bucket { ... }
read_resource_expr = {
    kw_read ~ trivia+ ~ namespaced_id ~ trivia* ~ open_brace ~ block_content* ~ close_brace
}

// Variable reference (with optional chained member access and index access)
// Supports: bucket.name, a.b.c, a[0].b, a["key"].b.c
variable_ref = { identifier ~ (field_access | index_access)* }
field_access = { "." ~ identifier }
index_access = { open_bracket ~ trivia* ~ expression ~ trivia* ~ close_bracket }

// Literals
boolean = { "true" | "false" }
float = @{ "-"? ~ ASCII_DIGIT+ ~ "." ~ ASCII_DIGIT+ }
number = @{ "-"? ~ ASCII_DIGIT+ }
string = ${ single_quoted_string | double_quoted_string }
double_quoted_string = ${ "\"" ~ inner_string ~ "\"" }
inner_string = @{ char* }
char = {
    !("\"" | "\\") ~ ANY
  | "\\" ~ ("\"" | "\\" | "n" | "r" | "t")
}
single_quoted_string = ${ "'" ~ single_quoted_inner ~ "'" }
single_quoted_inner = @{ single_quoted_char* }
single_quoted_char = {
    !("'" | "\\") ~ ANY
  | "\\" ~ ("'" | "\\")
}

// Tokens (for easier identification in CST)
open_brace = { "{" }
close_brace = { "}" }
open_bracket = { "[" }
close_bracket = { "]" }
open_paren = { "(" }
close_paren = { ")" }
equals = { "=" }
colon = { ":" }
comma = { "," }
pipe_op = { "|>" }
compose_op = { ">>" }

// Keywords
kw_provider = { "provider" }
kw_backend = { "backend" }
kw_import = { "import" }
kw_use = { "use" }
kw_let = { "let" }
kw_arguments = { "arguments" }
kw_attributes = { "attributes" }
kw_exports = { "exports" }
kw_list = { "list" }
kw_map = { "map" }
kw_struct = { "struct" }
kw_for = { "for" }
kw_in = { "in" }
kw_if = { "if" }
kw_else = { "else" }
kw_read = { "read" }
kw_fn = { "fn" }
kw_removed = { "removed" }
kw_moved = { "moved" }
kw_to = { "to" }
kw_from = { "from" }
kw_id = { "id" }
kw_require = { "require" }
kw_upstream_state = { "upstream_state" }
