// Carina DSL Grammar

// Entry point
file = { SOI ~ statement* ~ EOI }

statement = { backend_block | provider_block | arguments_block | attributes_block | exports_block | import_state_block | removed_block | moved_block | require_statement | if_expr | for_expr | fn_def | let_binding | module_call | anonymous_resource }

// Require statement: require <validate_expr>, "error message"
require_statement = { "require" ~ validate_expr ~ "," ~ string }

// Upstream state expression: upstream_state { source = "<dir>" }
// Declares a read-only reference to another Carina configuration's state.
// Used as the RHS of a `let` binding: `let orgs = upstream_state { source = "../organizations" }`.
upstream_state_expr = { "upstream_state" ~ "{" ~ attribute* ~ "}" }

// User-defined function: fn name(params) { body }
fn_def = { "fn" ~ identifier ~ "(" ~ fn_params? ~ ")" ~ (":" ~ type_expr)? ~ "{" ~ fn_body ~ "}" }
fn_params = { fn_param ~ ("," ~ fn_param)* }
fn_param = { identifier ~ (":" ~ type_expr)? ~ ("=" ~ expression)? }
fn_body = { fn_local_let* ~ expression }
fn_local_let = { "let" ~ identifier ~ "=" ~ expression }

// Arguments block: arguments { vpc_id: string, ... }
arguments_block = {
    "arguments" ~ "{" ~ arguments_param* ~ "}"
}

// Arguments parameter: name: type or name: type = default, or block form with description/default
arguments_param = {
    identifier ~ ":" ~ type_expr ~ arguments_param_block
  | identifier ~ ":" ~ type_expr ~ ("=" ~ expression)?
}

arguments_param_block = {
    "{" ~ arguments_param_attr* ~ "}"
}

arguments_param_attr = {
    arg_description_attr
  | arg_default_attr
  | arg_validation_block
}

arg_description_attr = { "description" ~ "=" ~ string }
arg_default_attr = { "default" ~ "=" ~ expression }
arg_validation_block = { "validation" ~ "{" ~ validation_block_attr* ~ "}" }
validation_block_attr = { validation_condition_attr | validation_error_message_attr }
validation_condition_attr = { "condition" ~ "=" ~ validate_expr }
validation_error_message_attr = { "error_message" ~ "=" ~ string }

// Validate expression: boolean expression with comparison and logical operators
// Used in arguments block to validate argument values at module call time
validate_expr = { validate_or_expr }
validate_or_expr = { validate_and_expr ~ ("||" ~ validate_and_expr)* }
validate_and_expr = { validate_not_expr ~ ("&&" ~ validate_not_expr)* }
validate_not_expr = { "!" ~ validate_not_expr | validate_comparison }
validate_comparison = { validate_primary ~ (compare_op ~ validate_primary)? }
compare_op = { ">=" | "<=" | "!=" | "==" | ">" | "<" }
validate_primary = {
    validate_function_call
  | null_literal
  | boolean
  | float
  | number
  | string
  | variable_ref
  | "(" ~ validate_expr ~ ")"
}
null_literal = { "null" ~ !(ASCII_ALPHANUMERIC | "_") }
validate_function_call = { identifier ~ "(" ~ (validate_expr ~ ("," ~ validate_expr)*)? ~ ")" }

// Attributes block: attributes { subnet_ids: list(string), ... }
attributes_block = {
    "attributes" ~ "{" ~ attributes_param* ~ "}"
}

// Attributes parameter: name: type = expr, or name = expr (type optional)
attributes_param = {
    identifier ~ ":" ~ type_expr ~ "=" ~ expression
  | identifier ~ "=" ~ expression
}

exports_block = {
    "exports" ~ "{" ~ exports_param* ~ "}"
}

// Exports parameter: name: type = expr, or name = expr (type optional)
exports_param = {
    identifier ~ ":" ~ type_expr ~ "=" ~ expression
  | identifier ~ "=" ~ expression
}

// Type expression: string, bool, int, float, cidr, arn, etc., list(type), map(type), aws.vpc (resource ref), struct { field: type, ... }
type_expr = { type_struct | type_ref | type_generic | type_simple }
type_simple = @{ identifier }
type_generic = { ("list" | "map") ~ "(" ~ type_expr ~ ")" }
type_ref = { resource_type_path }
resource_type_path = @{ identifier ~ ("." ~ identifier)+ }
type_struct = { "struct" ~ "{" ~ struct_field_list? ~ "}" }
struct_field_list = { struct_field ~ ("," ~ struct_field)* ~ ","? }
struct_field = { identifier ~ ":" ~ type_expr }

// Use expression: use { source = "<path>" }
// Loads a Carina module from the given source directory.
// Used as the RHS of a `let` binding: `let network = use { source = "./modules/network" }`.
use_expr = { "use" ~ "{" ~ attribute* ~ "}" }

// Backend block: backend s3 { bucket = "...", key = "...", ... }
backend_block = {
    "backend" ~ identifier ~ "{" ~ attribute* ~ "}"
}

// State manipulation blocks (import, removed, moved)

// Resource address: provider.service.type "name"
resource_address = { namespaced_id ~ string }

// Import state block: import { to = awscc.ec2.vpc "name", id = "vpc-xxx" }
import_state_block = {
    "import" ~ "{" ~ import_state_attr* ~ "}"
}
import_state_attr = { import_to_attr | import_id_attr }
import_to_attr = { "to" ~ "=" ~ resource_address }
import_id_attr = { "id" ~ "=" ~ string }

// Removed block: removed { from = awscc.ec2.vpc "name" }
removed_block = {
    "removed" ~ "{" ~ removed_attr* ~ "}"
}
removed_attr = { "from" ~ "=" ~ resource_address }

// Moved block: moved { from = awscc.ec2.vpc "old", to = awscc.ec2.vpc "new" }
moved_block = {
    "moved" ~ "{" ~ moved_attr* ~ "}"
}
moved_attr = { moved_from_attr | moved_to_attr }
moved_from_attr = { "from" ~ "=" ~ resource_address }
moved_to_attr = { "to" ~ "=" ~ resource_address }

// Module call: module_name { key = value, ... }
// `use` is reserved: it can only appear as the RHS of a top-level `let`
// binding (see `let_binding`). Without this guard, `use { ... }` would
// silently parse as a `module_call` named "use" once `use_expr` was
// removed from `primary` (issue #2233).
module_call = {
    !use_keyword ~ identifier ~ "{" ~ module_call_arg* ~ "}"
}
use_keyword = @{ "use" ~ !(ASCII_ALPHANUMERIC | "_") }

// Module call argument: key = value
module_call_arg = { identifier ~ "=" ~ expression }

// Anonymous resource: aws.s3_bucket { ... } (top-level)
anonymous_resource = { namespaced_id ~ "{" ~ block_content* ~ "}" }

// Provider block: provider aws { ... }
provider_block = {
    "provider" ~ identifier ~ "{" ~ attribute* ~ "}"
}

// Variable/resource definition: let name = value
// discard_pattern allows `let _ = expr` to suppress unused binding warnings
// `use_expr` is allowed only here (not in `expression`/`primary`) because it is
// not a value: it is a meta-statement handled specially by the let-binding
// evaluator. See issue #2233.
let_binding = { "let" ~ (discard_pattern | identifier) ~ "=" ~ (use_expr | expression) }
discard_pattern = @{ "_" }

// Block content: a local let binding, an attribute (key = value), or a nested block (key { ... })
block_content = { local_binding | attribute | nested_block }

// Local let binding inside a block: let name = expression
// These are block-scoped variables, NOT sent to the provider
local_binding = { "let" ~ identifier ~ "=" ~ expression }

// Attribute: key = value
// Keys can be identifiers or quoted strings (for keys with dots, colons, etc.)
attribute = { (identifier | string) ~ "=" ~ expression }

// Nested block: key { ... } (like Terraform's ingress { ... })
// Supports arbitrary nesting depth (block_content allows nested_block recursively)
nested_block = { identifier ~ "{" ~ block_content* ~ "}" }

identifier = @{ ASCII_ALPHA ~ (ASCII_ALPHANUMERIC | "_")* }

// Namespaced identifier: aws.s3_bucket, aws.Region.ap_northeast_1
// Segments after the first dot can also be digit-only (e.g., "Type.ipsec.1")
namespaced_id = @{ identifier ~ ("." ~ (identifier | ASCII_DIGIT+))+ }

// Namespaced identifier followed by one or more `[index]` subscripts:
// `orgs.accounts[0]`, `orgs.account.children["alpha"]`. Captured as a
// distinct rule so the namespaced_id arm doesn't have to introspect for
// trailing subscripts and so the grammar matches the issue-#2318
// surface (post-field index access) explicitly.
subscripted_id = { namespaced_id ~ index_access+ }

// Expression
expression = { coalesce_expr }

// Null coalescing: expr ?? default (returns left if resolved, right if unresolved reference)
coalesce_expr = { pipe_expr ~ ("??" ~ pipe_expr)? }

// Pipe operator: value |> func |> func
pipe_expr = { compose_expr ~ ("|>" ~ function_call)* }

// Compose operator: f >> g (function composition, binds tighter than |>)
compose_expr = { primary ~ (">>" ~ primary)* }

// Function call: func(args)
function_call = { identifier ~ "(" ~ (expression ~ ("," ~ expression)*)? ~ ")" }

// Primary value
// Note: `use_expr` is intentionally NOT a primary. It is a meta-statement,
// not a value, and is only valid as the RHS of a top-level `let` binding
// (see `let_binding`). Allowing it here would let it parse silently in
// positions the evaluator cannot handle (issue #2233).
primary = {
    read_resource_expr   // Must come before resource_expr for "read aws..." parsing
  | upstream_state_expr  // Must come before module_call so "upstream_state { ... }" is not parsed as a module call
  | resource_expr
  | for_expr             // Must come before module_call so "for" is not parsed as module name
  | if_expr              // Must come before module_call so "if" is not parsed as module name
  | module_call          // Must come before variable_ref so "name { ... }" is parsed as module call
  | function_call        // Must come before variable_ref so "func(...)" is parsed as function call
  | list
  | map
  | subscripted_id      // Must come before namespaced_id so "a.b[0]" doesn't bottom out as "a.b"
  | namespaced_id
  | boolean
  | float
  | number
  | string
  | variable_ref
  | "(" ~ expression ~ ")"
}

// For expression: for var in iterable { body }
// Supports: for x in list, for (i, x) in list, for k, v in map
for_expr = {
    "for" ~ for_binding ~ "in" ~ for_iterable ~ "{" ~ for_body ~ "}"
}

// For binding: simple (x), indexed ((i, x)), or map (k, v).
// `_` is accepted in any position as a discard pattern (same semantics as
// `let _ = ...`): the binding is not registered and is exempt from the
// unused-binding warning.
for_binding = { for_indexed_binding | for_map_binding | for_simple_binding }
for_simple_binding = { discard_pattern | identifier }
for_indexed_binding = { "(" ~ (discard_pattern | identifier) ~ "," ~ (discard_pattern | identifier) ~ ")" }
for_map_binding = { (discard_pattern | identifier) ~ "," ~ (discard_pattern | identifier) }

// For iterable: restricted to simple expressions to avoid ambiguity with body block
for_iterable = { function_call | list | variable_ref | "(" ~ expression ~ ")" }

// For body: local let bindings followed by a resource expression or module call
for_body = { for_local_binding* ~ (read_resource_expr | resource_expr | module_call) }
for_local_binding = { "let" ~ identifier ~ "=" ~ expression }

// If expression: if condition { body } else { body }
if_expr = { "if" ~ expression ~ "{" ~ if_body ~ "}" ~ else_clause? }
else_clause = { "else" ~ "{" ~ if_body ~ "}" }
if_body = { if_local_binding* ~ (read_resource_expr | resource_expr | module_call | expression) }
if_local_binding = { "let" ~ identifier ~ "=" ~ expression }

// List: [item1, item2, ...]
list = { "[" ~ (expression ~ ("," ~ expression)*)? ~ ","? ~ "]" }

// Map: { key = value, ... } (commas are optional, newlines work too)
map = { "{" ~ (map_entry | nested_block)* ~ "}" }

// Map entry: key = value (with optional trailing comma)
// Keys can be identifiers or quoted strings (for keys with dots, colons, etc.)
map_entry = { (identifier | string) ~ "=" ~ expression ~ ","? }

// Resource expression: aws.s3_bucket { ... }
resource_expr = { namespaced_id ~ "{" ~ block_content* ~ "}" }

// Read resource expression (data source): read aws.s3_bucket { ... }
read_resource_expr = { "read" ~ namespaced_id ~ "{" ~ block_content* ~ "}" }

// Variable reference (with optional chained member access and index access)
// Supports: bucket.name, a.b.c, a[0].b, a["key"].b.c
variable_ref = { identifier ~ (field_access | index_access)* }
field_access = { "." ~ identifier }
index_access = { "[" ~ expression ~ "]" }

// Literals
boolean = { "true" | "false" }
float = @{ "-"? ~ ASCII_DIGIT+ ~ "." ~ ASCII_DIGIT+ }
number = @{ "-"? ~ ASCII_DIGIT+ }
string = ${ single_quoted_string | double_quoted_string }
double_quoted_string = ${ "\"" ~ string_part* ~ "\"" }
string_part = ${ interpolation | string_literal }
// `expression` is optional so a mid-edit empty `${}` doesn't abort
// the AST. `inline_ws*` (space/tab only) lets `${ }` parse too —
// `WHITESPACE` is auto-disabled inside compound-atomic (`${ ... }`)
// rules, so without an explicit allowance the inner whitespace is
// rejected. Newlines are deliberately excluded so the parser stays
// in sync with the single-line LSP `check_empty_interpolations`
// scanner — no silent gap where `${\n}` parses but no diagnostic
// fires. See #2480.
interpolation = ${ "${" ~ inline_ws* ~ expression? ~ inline_ws* ~ "}" }
inline_ws = _{ " " | "\t" }
string_literal = @{ string_char+ }
string_char = {
    !("\"" | "\\" | "${") ~ ANY
  | "\\" ~ ("\"" | "\\" | "n" | "r" | "t" | "$")
  | "$" ~ !("{")
}

// Single-quoted strings: literal only, no interpolation
single_quoted_string = ${ "'" ~ single_quoted_content ~ "'" }
single_quoted_content = @{ single_quoted_char* }
single_quoted_char = {
    !("'" | "\\") ~ ANY
  | "\\" ~ ("'" | "\\")
}

// Whitespace (auto-skip)
WHITESPACE = _{ " " | "\t" | NEWLINE }

// Comment (auto-skip)
COMMENT = _{ block_comment | line_comment }
line_comment = _{ ("//" | "#") ~ (!NEWLINE ~ ANY)* }
block_comment = _{ "/*" ~ (block_comment | (!"*/" ~ ANY))* ~ "*/" }
