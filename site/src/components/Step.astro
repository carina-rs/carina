---
interface Props {
  number: number;
  eyebrow?: string;
  title: string;
}

const { number, eyebrow, title } = Astro.props;
---
<li class="step">
  <div class="step-marker" aria-hidden="true">{number}</div>
  <div class="step-body">
    {eyebrow && <p class="step-eyebrow">{eyebrow}</p>}
    <h3 class="step-title" set:html={title} />
    <div class="step-content"><slot /></div>
  </div>
</li>

<style>
  .step {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: var(--space-4);
    align-items: start;
  }

  .step-marker {
    width: 2.5rem;
    height: 2.5rem;
    display: grid;
    place-items: center;
    border-radius: 9999px;
    background: var(--accent);
    color: var(--bg);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--text-base);
  }

  .step-body { min-width: 0; }

  .step-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg3);
    margin: 0 0 var(--space-1);
  }

  .step-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--fg1);
    margin: 0 0 var(--space-3);
    line-height: var(--lh-tight);
  }

  .step-title :global(code) {
    font-size: 0.95em;
  }

  .step-content > :global(:first-child) { margin-top: 0; }
  .step-content > :global(:last-child) { margin-bottom: 0; }
</style>
